{
  "name": "voidline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm:build": "node scripts/build-wasm.mjs",
    "predev": "npm run wasm:build",
    "dev": "vite",
    "build": "npm run wasm:build && tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run wasm:build",
    "test": "vitest run",
    "test:balance": "vitest run src/game/balance.test.ts src/game/balance-curves.test.ts",
    "data:export": "cross-env RUN_DATA_EXPORT=1 vitest run scripts/export-balance.test.ts",
    "data:check": "cross-env CHECK_DATA_EXPORT=1 vitest run scripts/export-balance.test.ts",
    "balance:meta-report": "scripts/balance-dispatch.sh meta-report",
    "balance:meta-report:quick": "scripts/balance-dispatch.sh meta-report-quick",
    "balance:profile": "scripts/balance-dispatch.sh profile",
    "balance:profile:quick": "scripts/balance-dispatch.sh profile-quick",
    "balance:profile:check": "scripts/balance-dispatch.sh profile-check",
    "balance:rl:train:baseline": "scripts/balance-dispatch.sh rl-train-baseline",
    "balance:rl:report:quick": "scripts/balance-dispatch.sh rl-report-quick",
    "balance:rl:report": "scripts/balance-dispatch.sh rl-report",
    "balance:rl:check": "scripts/balance-dispatch.sh rl-check",
    "balance:rl:smoke": "scripts/balance-dispatch.sh rl-smoke",
    "balance:sweep:quick": "scripts/balance-dispatch.sh sweep-quick",
    "balance:sweep:check": "scripts/balance-dispatch.sh sweep-check",
    "balance:phase2:quick": "scripts/balance-dispatch.sh phase2-quick",
    "balance:phase3:quick": "scripts/balance-dispatch.sh phase3-quick",
    "balance:modal:profile:check": "VOIDLINE_BALANCE_BACKEND=modal scripts/balance-dispatch.sh profile-check",
    "balance:modal:sweep:check": "VOIDLINE_BALANCE_BACKEND=modal scripts/balance-dispatch.sh sweep-check",
    "balance:modal:phase2:quick": "VOIDLINE_BALANCE_BACKEND=modal scripts/balance-dispatch.sh phase2-quick",
    "balance:modal:phase3:quick": "VOIDLINE_BALANCE_BACKEND=modal scripts/balance-dispatch.sh phase3-quick",
    "balance:modal:rl:train": "VOIDLINE_BALANCE_BACKEND=modal scripts/balance-dispatch.sh rl-train-baseline",
    "balance:modal:pull": "scripts/balance-modal-pull.sh",
    "test:watch": "vitest",
    "prebench": "npm run wasm:build",
    "bench": "vitest bench --run",
    "smoke": "npm run build && node scripts/browser-smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "playwright": "1.58.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wasm-pack": "^0.14.0"
  },
  "dependencies": {
    "phaser": "4.0.0"
  },
  "overrides": {
    "axios": "^1.15.2",
    "tar": "^7.5.13"
  }
}
