{
  "name": "voidline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:balance": "vitest run src/game/balance.test.ts src/game/balance-simulation.test.ts",
    "balance:report": "RUN_BALANCE_REPORT=1 vitest run scripts/balance-report.test.ts",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "smoke": "npm run build && node scripts/browser-smoke.mjs"
  },
  "devDependencies": {
    "playwright": "1.58.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "phaser": "4.0.0"
  }
}
