{
  "name": "voidline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "vercel dev",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && npm run sim:test",
    "test:watch": "vitest",
    "smoke": "npm run build && node scripts/browser-smoke.mjs",
    "sim:test": "cargo test --manifest-path sim/Cargo.toml",
    "bench:run": "cargo run -q --release --manifest-path sim/Cargo.toml -p voidline-bench -- run",
    "bench:campaign": "cargo run -q --release --manifest-path sim/Cargo.toml -p voidline-bench -- campaign"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vercel/node": "^5.7.15",
    "playwright": "1.58.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "phaser": "4.0.0"
  },
  "overrides": {
    "axios": "^1.15.2",
    "tar": "^7.5.13"
  }
}
