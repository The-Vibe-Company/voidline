{
  "name": "voidline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm:build": "node scripts/build-wasm.mjs",
    "predev": "npm run wasm:build",
    "dev": "vite",
    "build": "npm run wasm:build && tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run wasm:build",
    "test": "vitest run",
    "test:balance": "vitest run src/game/balance.test.ts src/game/balance-curves.test.ts",
    "data:export": "cross-env RUN_DATA_EXPORT=1 vitest run scripts/export-balance.test.ts",
    "data:check": "cross-env CHECK_DATA_EXPORT=1 vitest run scripts/export-balance.test.ts",
    "balance:meta-report": "scripts/meta-progression-report.sh --default",
    "balance:meta-report:quick": "scripts/meta-progression-report.sh --quick",
    "balance:profile": "scripts/balance-profile.sh",
    "balance:profile:quick": "scripts/balance-profile.sh --quick",
    "balance:profile:check": "scripts/balance-profile.sh --check",
    "balance:sweep:quick": "scripts/meta-progression-report.sh --default --player-profile expert-human --policy-set focused --campaigns 6 --runs 80 --max-pressure 80 --trial-seconds 720 --max-seconds 180 --output scripts/balance-sweep-report.json",
    "balance:sweep:check": "scripts/meta-progression-report.sh --default --player-profile skilled --policy-set focused --campaigns 12 --runs 120 --max-pressure 80 --trial-seconds 720 --max-seconds 360 --check-target balance --output scripts/balance-sweep-report.json",
    "balance:phase2:quick": "scripts/meta-progression-report.sh --default --phase stage2 --player-profile expert-human --policy-set focused --campaigns 6 --runs 80 --max-pressure 80 --trial-seconds 720 --max-seconds 180 --output scripts/balance-phase2-report.json",
    "balance:phase3:quick": "scripts/meta-progression-report.sh --default --phase stage3 --player-profile expert-human --policy-set focused --campaigns 6 --runs 80 --max-pressure 80 --trial-seconds 720 --max-seconds 180 --output scripts/balance-phase3-report.json",
    "test:watch": "vitest",
    "prebench": "npm run wasm:build",
    "bench": "vitest bench --run",
    "smoke": "npm run build && node scripts/browser-smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "playwright": "1.58.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wasm-pack": "^0.14.0"
  },
  "dependencies": {
    "phaser": "4.0.0"
  },
  "overrides": {
    "axios": "^1.15.2",
    "tar": "^7.5.13"
  }
}
